# =====================================================
# IR Bot Deal Room — Environment Variables
# Copy to server/.env and fill in values
# =====================================================

# Runtime
NODE_ENV=production
PORT=3005

# Security — generate with: openssl rand -base64 48
JWT_SECRET=<generate-strong-secret>

# CORS — frontend URL
CLIENT_URL=https://dealroom.graycapitalllc.com

# Supabase (optional — app falls back to demo/in-memory mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# AI
ANTHROPIC_API_KEY=

# HubSpot CRM
HUBSPOT_API_KEY=
HUBSPOT_MEETING_URL=
HUBSPOT_INSTITUTIONAL_FORM_URL=

# Investment Portal
INVESTMENT_PORTAL_URL=https://investors.appfolioim.com/graycapitalllc

# Admin Access
ADMIN_EMAILS=spencer@graycapitalllc.com
ADMIN_PASSWORD=

# Error Tracking (optional)
SENTRY_DSN=
